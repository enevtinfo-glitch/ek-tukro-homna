rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bloodRequests
    // Fields:
    //   - bloodGroup: string (required, enum)
    //   - location: string (required, min: 3, max: 200)
    //   - contactNumber: string (required, min: 10, max: 15)
    //   - status: string (required, enum: pending, fulfilled)
    //   - createdAt: timestamp (required)
    //   - uid: string (required)
    //
    // Collection: donors
    // Fields:
    //   - name: string (required, min: 2, max: 100)
    //   - bloodGroup: string (required, enum)
    //   - location: string (required, min: 3, max: 200)
    //   - mobileNumber: string (required, min: 10, max: 15)
    //   - lastDonationDate: string (optional, ISO date)
    //   - donationCount: int (optional, min: 0)
    //   - donationHistory: list (optional, max: 50)
    //   - uid: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Fields:
    //   - email: string (required, email)
    //   - role: string (required, enum: admin, moderator, editor)
    //   - uid: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ( (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() == 'admin') ||
          (request.auth.token.email == "enevtinfo@gmail.com") );
    }

    function isModerator() {
      return isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() in ['admin', 'moderator']);
    }

    function isEditor() {
      return isAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() in ['admin', 'moderator', 'editor']);
    }

    function isValidBloodGroup(bg) {
      return bg in ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"];
    }

    function hasOnlyAllowedFields(data, allowedFields) {
      return data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(data, requiredFields) {
      return data.keys().hasAll(requiredFields);
    }

    function isValidBloodRequest(data) {
      return hasRequiredFields(data, ['bloodGroup', 'location', 'contactNumber', 'status', 'createdAt', 'uid']) &&
             hasOnlyAllowedFields(data, ['bloodGroup', 'location', 'contactNumber', 'status', 'createdAt', 'uid']) &&
             isValidBloodGroup(data.bloodGroup) &&
             data.location is string && data.location.size() >= 3 && data.location.size() <= 200 &&
             data.contactNumber is string && data.contactNumber.size() >= 10 && data.contactNumber.size() <= 15 &&
             data.status in ['pending', 'fulfilled'] &&
             data.createdAt is timestamp &&
             data.uid is string && data.uid.size() < 100;
    }

    function isValidDonor(data) {
      return hasRequiredFields(data, ['name', 'bloodGroup', 'location', 'mobileNumber', 'uid', 'createdAt']) &&
             hasOnlyAllowedFields(data, ['name', 'bloodGroup', 'location', 'mobileNumber', 'uid', 'createdAt', 'lastDonationDate', 'donationCount', 'donationHistory']) &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             isValidBloodGroup(data.bloodGroup) &&
             data.location is string && data.location.size() >= 3 && data.location.size() <= 200 &&
             data.mobileNumber is string && data.mobileNumber.size() >= 10 && data.mobileNumber.size() <= 15 &&
             data.createdAt is timestamp &&
             data.uid is string && data.uid.size() < 100 &&
             (!('lastDonationDate' in data) || (data.lastDonationDate is string && data.lastDonationDate.size() <= 10)) &&
             (!('donationCount' in data) || (data.donationCount is int && data.donationCount >= 0)) &&
             (!('donationHistory' in data) || (data.donationHistory is list && data.donationHistory.size() <= 50));
    }

    function isValidUser(data) {
      return hasRequiredFields(data, ['email', 'role', 'uid']) &&
             hasOnlyAllowedFields(data, ['email', 'role', 'uid']) &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['admin', 'moderator', 'editor'] &&
             data.uid is string && data.uid.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Blood Requests:
    match /bloodRequests/{requestId} {
      allow read: if true;
      // Public creation allowed as per user request (no login needed)
      allow create: if isValidBloodRequest(request.resource.data);
      // Updates require editor role and must maintain data validity
      allow update: if isEditor() && isValidBloodRequest(request.resource.data);
      // Deletion requires moderator role
      allow delete: if isModerator();
    }

    // Donors:
    match /donors/{donorId} {
      allow read: if true;
      // Public creation allowed as per user request (no login needed)
      allow create: if isValidDonor(request.resource.data);
      // Updates require editor role and must maintain data validity
      allow update: if isEditor() && isValidDonor(request.resource.data);
      // Deletion requires moderator role
      allow delete: if isModerator();
    }

    // Users (Roles):
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    // Profiles (Publicly readable names/photos, but private emails)
    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
